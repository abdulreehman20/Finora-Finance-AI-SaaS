# ── Application URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_BACKEND_URL=

# ── Neon Database ────────────────────────────────────────────────────────────

DATABASE_URL=


# ── Better-Auth ────────────────────────────────────────────────────────────

BETTER_AUTH_APP_NAME=
BETTER_AUTH_SECRET=


# ── Resend Email ────────────────────────────────────────────────────────────

MAILER_SENDER=
RESEND_API_KEY=


# ── Google Auth ────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Gemini AI ────────────────────────────────────────────────────────────

GEMINI_API_KEY=

# ── Cloudinary Storage ────────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Stripe Payments ────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=                # sk_test_... from Stripe Dashboard -> Developers -> API Keys
STRIPE_WEBHOOK_SECRET=            # whsec_... from Stripe Dashboard -> Developers -> Webhooks
STRIPE_PRO_PRICE_ID=              # price_... — the Pro plan price ID from Stripe






